@model SHA.FluentEmail.MVC.Models.EmailViewModel

@{
    ViewData["Title"] = "Send Email";
}

<div class="email-container">
    <div class="email-card glass">
        <div class="card-header">
            <h1><i class="fas fa-paper-plane"></i> Send Email</h1>
            <p>Compose and send your message using FluentEmail</p>
        </div>

        @if (ViewBag.Message != null)
        {
            var isSuccess = ViewBag.Message.ToString().Contains("successfully");
            <div class="alert @(isSuccess ? "alert-success" : "alert-danger") animate-fade-in">
                <i class="fas @(isSuccess ? "fa-check-circle" : "fa-exclamation-triangle")"></i>
                @ViewBag.Message
            </div>
        }

        <form asp-action="Send" method="post" class="email-form">
            <div class="form-group">
                <label asp-for="ToEmail"></label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope"></i>
                    <input asp-for="ToEmail" class="form-control" placeholder="recipient@example.com" />
                </div>
                <span asp-validation-for="ToEmail" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Subject"></label>
                <div class="input-wrapper">
                    <i class="fas fa-heading"></i>
                    <input asp-for="Subject" class="form-control" placeholder="Enter subject" />
                </div>
                <span asp-validation-for="Subject" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Body"></label>
                <div class="input-wrapper">
                    <textarea asp-for="Body" class="form-control" rows="6" placeholder="Write your message here..."></textarea>
                </div>
                <span asp-validation-for="Body" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-glow">
                    <span>Send Message</span>
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    :root {
        --primary-color: #6366f1;
        --primary-hover: #4f46e5;
        --bg-gradient: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.1);
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
    }

    .email-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 2rem;
    }

    .glass {
        background: var(--glass-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border);
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
    }

    .email-card {
        width: 100%;
        max-width: 600px;
        border-radius: 24px;
        padding: 2.5rem;
        animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .card-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .card-header h1 {
        font-size: 2rem;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 0.5rem;
        letter-spacing: -0.025em;
    }

    .card-header h1 i {
        color: var(--primary-color);
        margin-right: 0.75rem;
    }

    .card-header p {
        color: var(--text-muted);
        font-size: 1rem;
    }

    .email-form .form-group {
        margin-bottom: 1.5rem;
    }

    .email-form label {
        display: block;
        color: var(--text-main);
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-wrapper i {
        position: absolute;
        left: 1rem;
        color: var(--text-muted);
        pointer-events: none;
        transition: color 0.3s ease;
    }

    .form-control {
        width: 100%;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 0.75rem 1rem 0.75rem 2.75rem;
        color: var(--text-main);
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    textarea.form-control {
        padding-left: 1rem;
    }

    .form-control:focus {
        background: rgba(0, 0, 0, 0.3);
        border-color: var(--primary-color);
        outline: none;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }

    .form-control:focus + i {
        color: var(--primary-color);
    }

    .form-actions {
        margin-top: 2.5rem;
    }

    .btn-primary {
        width: 100%;
        background: var(--primary-color);
        border: none;
        border-radius: 12px;
        padding: 1rem;
        color: white;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.75rem;
        transition: all 0.3s ease;
    }

    .btn-glow:hover {
        background: var(--primary-hover);
        box-shadow: 0 0 20px rgba(99, 102, 241, 0.4);
        transform: translateY(-2px);
    }

    .btn-glow:active {
        transform: translateY(0);
    }

    .alert {
        padding: 1rem;
        border-radius: 12px;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-weight: 500;
    }

    .alert-success {
        background: rgba(34, 197, 94, 0.1);
        border: 1px solid rgba(34, 197, 94, 0.2);
        color: #4ade80;
    }

    .alert-danger {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #f87171;
    }

    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>

<!-- Add FontAwesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
